{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "agent_theme_companion",
  "version": "0.1.0",
  "identifier": "com.agenttheme.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "../themes": "themes"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
